<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/epg_scrim_background">

    <androidx.cardview.widget.CardView
        android:id="@+id/rewindCard"
        android:layout_width="640dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        app:cardBackgroundColor="#00000000"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/epg_glass_panel"
            android:padding="32dp">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_time"
                    app:tint="#F1F5F9"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jump to Time"
                    android:textColor="#F1F5F9"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>

                <TextView
                    android:id="@+id/tvArchiveRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:alpha="0.8"/>

            </LinearLayout>

            <!-- Selection Visualizer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/epg_header_bar"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/tvSelectedTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today  00:00"
                    android:textColor="#F1F5F9"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01"/>

                <TextView
                    android:id="@+id/tvOutOfRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Outside archive window"
                    android:textColor="#EF4444"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/epg_divider_line"
                android:layout_marginVertical="20dp"/>

            <!-- Picker Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:orientation="horizontal"
                android:gravity="center">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDays"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2.2"
                    android:clipToPadding="false"
                    android:paddingTop="74dp"
                    android:paddingBottom="74dp"
                    android:scrollbars="none"
                    android:focusable="true"/>

                <View android:layout_width="1dp" android:layout_height="match_parent" 
                    android:background="@drawable/epg_divider_line" android:layout_marginHorizontal="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHours"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingTop="74dp"
                    android:paddingBottom="74dp"
                    android:scrollbars="none"
                    android:focusable="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textColor="#F1F5F9"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp"
                    android:layout_marginHorizontal="4dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMinutes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingTop="74dp"
                    android:paddingBottom="74dp"
                    android:scrollbars="none"
                    android:focusable="true"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/epg_divider_line"
                android:layout_marginVertical="20dp"/>

            <Button
                android:id="@+id/btnRewindConfirm"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="WATCH FROM THIS TIME"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E52121"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:focusable="true"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>