<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Logo top-left -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="140dp"
            android:layout_height="29dp"
            android:src="@drawable/ic_mediabox_logo"
            android:scaleType="fitStart"
            android:contentDescription="Mediabox"
            android:layout_marginStart="48dp"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Top-right: Lang toggle + Clock -->
        <LinearLayout
            android:id="@+id/topRightGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="48dp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Language toggle pill -->
            <LinearLayout
                android:id="@+id/btnLang"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/menu_card_glass"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:focusable="true"
                android:clickable="true"
                android:alpha="0.65"
                android:layout_marginEnd="22dp">

                <TextView
                    android:id="@+id/tvLangLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ქართ"
                    android:textColor="#F1F5F9"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"/>

            </LinearLayout>

            <!-- Clock -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#D0F1F5F9"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.04"
                    android:fontFamily="sans-serif-light"/>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mon, 1 Jan"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp"
                    android:gravity="end"
                    android:letterSpacing="0.06"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Subtle horizontal rule -->
        <View
            android:id="@+id/dividerTop"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#12FFFFFF"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="48dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/topRightGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Cards row — centered vertically -->
        <LinearLayout
            android:id="@+id/cardsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/dividerTop"
            app:layout_constraintBottom_toTopOf="@+id/hintBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ═══════════════ WATCH TV ═══════════════ -->
            <FrameLayout
                android:id="@+id/cardWatchTv"
                android:layout_width="240dp"
                android:layout_height="220dp"
                android:layout_margin="20dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- Icon: monitor with play arrow (premium SVG) -->
                    <ImageView
                        android:tag="icon"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_menu_watch"
                        android:alpha="0.75"
                        android:scaleType="fitCenter"
                        android:contentDescription="Watch TV"/>

                    <!-- Accent line -->
                    <View
                        android:tag="labelAccent"
                        android:layout_width="24dp"
                        android:layout_height="2dp"
                        android:background="#E8191A"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0"/>

                    <TextView
                        android:tag="label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ტელევიზია"
                        android:textColor="#F1F5F9"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="-0.01"
                        android:alpha="0.85"/>

                    <TextView
                        android:tag="sublabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="პირდაპირი · არქივი · HD"
                        android:textColor="#55FFFFFF"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="5dp"
                        android:alpha="0"/>

                </LinearLayout>
            </FrameLayout>

            <!-- ═══════════════ PROFILE ═══════════════ -->
            <FrameLayout
                android:id="@+id/cardProfile"
                android:layout_width="240dp"
                android:layout_height="220dp"
                android:layout_margin="20dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <ImageView
                        android:tag="icon"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_menu_profile"
                        android:alpha="0.75"
                        android:scaleType="fitCenter"
                        android:contentDescription="Profile"/>

                    <View
                        android:tag="labelAccent"
                        android:layout_width="24dp"
                        android:layout_height="2dp"
                        android:background="#E8191A"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0"/>

                    <TextView
                        android:tag="label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="პროფილი"
                        android:textColor="#F1F5F9"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="-0.01"
                        android:alpha="0.85"/>

                    <TextView
                        android:tag="sublabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ანგარიში · გამოწერა"
                        android:textColor="#55FFFFFF"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="5dp"
                        android:alpha="0"/>

                </LinearLayout>
            </FrameLayout>

            <!-- ═══════════════ PLANS ═══════════════ -->
            <FrameLayout
                android:id="@+id/cardSettings"
                android:layout_width="240dp"
                android:layout_height="220dp"
                android:layout_margin="20dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <ImageView
                        android:tag="icon"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_menu_settings"
                        android:alpha="0.75"
                        android:scaleType="fitCenter"
                        android:contentDescription="Plans"/>

                    <View
                        android:tag="labelAccent"
                        android:layout_width="24dp"
                        android:layout_height="2dp"
                        android:background="#E8191A"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0"/>

                    <TextView
                        android:tag="label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="პაკეტები"
                        android:textColor="#F1F5F9"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="-0.01"
                        android:alpha="0.85"/>

                    <TextView
                        android:tag="sublabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="პაკეტები · ბალანსი"
                        android:textColor="#55FFFFFF"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="5dp"
                        android:alpha="0"/>

                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- Selection hint -->
        <LinearLayout
            android:id="@+id/hintBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvSelectionHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="პირდაპირი TV და საარქივო კონტენტი"
                android:textColor="#28FFFFFF"
                android:textSize="12sp"
                android:letterSpacing="0.02"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀  ▶  ნავიგაცია     ▲  ენა     OK  არჩევა"
                android:textColor="#12FFFFFF"
                android:textSize="9sp"
                android:letterSpacing="0.06"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>