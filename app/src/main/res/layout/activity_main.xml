<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Subtle Background Vignette -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/vignette_overlay" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="52dp"
            android:paddingEnd="52dp"
            android:paddingTop="28dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="130dp"
                android:layout_height="27dp"
                android:src="@drawable/ic_mediabox_logo"
                android:scaleType="fitStart" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="end">
                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#F1F5F9" android:textSize="26sp" android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#4094A3B8" android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- CAROUSEL AREA -->
        <FrameLayout
            android:id="@+id/cardsCarousel"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/headerBar"
            app:layout_constraintBottom_toTopOf="@id/hintBar">

            <!-- WATCH TV CARD -->
            <FrameLayout
                android:id="@+id/cardWatchTv"
                android:layout_width="220dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:background="@drawable/menu_card_glass"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="20dp">
                    <ImageView android:tag="icon" android:layout_width="65dp" android:layout_height="65dp"
                        android:src="@drawable/ic_menu_watch" app:tint="#F1F5F9" />
                    <TextView android:tag="label" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#F1F5F9" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="15dp"/>
                    <TextView android:tag="sublabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#94A3B8" android:textSize="11sp" android:alpha="0" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- RADIO CARD -->
            <FrameLayout
                android:id="@+id/cardRadio"
                android:layout_width="220dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:background="@drawable/menu_card_glass"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="20dp">
                    <ImageView android:tag="icon" android:layout_width="65dp" android:layout_height="65dp"
                        android:src="@drawable/ic_radio" app:tint="#F1F5F9" />
                    <TextView android:tag="label" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#F1F5F9" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="15dp"/>
                    <TextView android:tag="sublabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#94A3B8" android:textSize="11sp" android:alpha="0" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- PROFILE CARD -->
            <FrameLayout
                android:id="@+id/cardProfile"
                android:layout_width="220dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:background="@drawable/menu_card_glass"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="20dp">
                    <ImageView android:tag="icon" android:layout_width="65dp" android:layout_height="65dp"
                        android:src="@drawable/ic_menu_profile" app:tint="#F1F5F9" />
                    <TextView android:tag="label" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#F1F5F9" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="15dp"/>
                    <TextView android:tag="sublabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#94A3B8" android:textSize="11sp" android:alpha="0" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>

        <!-- EDGE GRADIENTS (Full Height) -->
        <View
            android:id="@+id/fadeLeft"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="@drawable/side_fade_left"
            android:elevation="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/fadeRight"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="@drawable/side_fade_right"
            android:elevation="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- HINT BAR -->
        <LinearLayout
            android:id="@+id/hintBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:gravity="center">
            <TextView
                android:id="@+id/tvSelectionHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#94A3B8"
                android:textSize="15sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include android:id="@+id/subNotificationOverlay" layout="@layout/overlay_subscription_notification" />
</FrameLayout>