<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- ══ HEADER ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="52dp"
            android:paddingEnd="52dp"
            android:paddingTop="28dp"
            android:paddingBottom="18dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="136dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_mediabox_logo"
                android:scaleType="fitStart"
                android:contentDescription="Mediabox"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#E2E8F0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"
                    android:fontFamily="sans-serif-light"/>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mon, 1 Jan"
                    android:textColor="#3894A3B8"
                    android:textSize="10sp"
                    android:gravity="end"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Hairline rule -->
        <View
            android:id="@+id/dividerTop"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#08FFFFFF"
            android:layout_marginStart="52dp"
            android:layout_marginEnd="52dp"
            app:layout_constraintTop_toBottomOf="@id/headerBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ══ CARDS ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cardsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/dividerTop"
            app:layout_constraintBottom_toTopOf="@id/hintBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ─── WATCH TV ─── -->
            <FrameLayout
                android:id="@+id/cardWatchTv"
                android:layout_width="215dp"
                android:layout_height="258dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="36dp"
                    android:paddingBottom="30dp">

                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp">

                        <View
                            android:tag="iconBg"
                            android:layout_width="76dp"
                            android:layout_height="76dp"
                            android:background="@drawable/card_icon_bg"/>

                        <!-- src points to original working icon drawable -->
                        <ImageView
                            android:tag="icon"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu_watch"
                            android:alpha="0.55"
                            android:scaleType="fitCenter"
                            android:contentDescription="Watch TV"/>
                    </FrameLayout>

                    <View
                        android:tag="labelAccent"
                        android:layout_width="32dp"
                        android:layout_height="2dp"
                        android:background="#E8191A"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0"/>

                    <TextView
                        android:tag="label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ტელევიზია"
                        android:textColor="#CBD5E1"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="-0.01"
                        android:alpha="0.7"/>

                    <TextView
                        android:tag="sublabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="პირდაპირი · არქივი · HD"
                        android:textColor="#3E94A3B8"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:letterSpacing="0.01"
                        android:layout_marginTop="7dp"
                        android:alpha="0"/>

                </LinearLayout>
            </FrameLayout>

            <!-- ─── RADIO ─── -->
            <FrameLayout
                android:id="@+id/cardRadio"
                android:layout_width="215dp"
                android:layout_height="258dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="36dp"
                    android:paddingBottom="30dp">

                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp">

                        <View
                            android:tag="iconBg"
                            android:layout_width="76dp"
                            android:layout_height="76dp"
                            android:background="@drawable/card_icon_bg"/>

                        <!-- ic_radio is the original working radio drawable -->
                        <ImageView
                            android:tag="icon"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_radio"
                            android:alpha="0.55"
                            android:scaleType="fitCenter"
                            android:contentDescription="Radio"/>
                    </FrameLayout>

                    <View
                        android:tag="labelAccent"
                        android:layout_width="32dp"
                        android:layout_height="2dp"
                        android:background="#E8191A"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0"/>

                    <TextView
                        android:tag="label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="რადიო"
                        android:textColor="#CBD5E1"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="-0.01"
                        android:alpha="0.7"/>

                    <TextView
                        android:tag="sublabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="სადგურები · მუსიკა"
                        android:textColor="#3E94A3B8"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:letterSpacing="0.01"
                        android:layout_marginTop="7dp"
                        android:alpha="0"/>

                </LinearLayout>
            </FrameLayout>

            <!-- ─── PROFILE ─── -->
            <FrameLayout
                android:id="@+id/cardProfile"
                android:layout_width="215dp"
                android:layout_height="258dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="36dp"
                    android:paddingBottom="30dp">

                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp">

                        <View
                            android:tag="iconBg"
                            android:layout_width="76dp"
                            android:layout_height="76dp"
                            android:background="@drawable/card_icon_bg"/>

                        <!-- ic_menu_profile is the original working profile drawable -->
                        <ImageView
                            android:tag="icon"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu_profile"
                            android:alpha="0.55"
                            android:scaleType="fitCenter"
                            android:contentDescription="Profile"/>
                    </FrameLayout>

                    <View
                        android:tag="labelAccent"
                        android:layout_width="32dp"
                        android:layout_height="2dp"
                        android:background="#E8191A"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="10dp"
                        android:alpha="0"/>

                    <TextView
                        android:tag="label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="პროფილი"
                        android:textColor="#CBD5E1"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:letterSpacing="-0.01"
                        android:alpha="0.7"/>

                    <TextView
                        android:tag="sublabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ანგარიში · გამოწერა"
                        android:textColor="#3E94A3B8"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:letterSpacing="0.01"
                        android:layout_marginTop="7dp"
                        android:alpha="0"/>

                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- ══ HINT BAR ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/hintBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="22dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvSelectionHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#20FFFFFF"
                android:textSize="12sp"
                android:letterSpacing="0.01"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀  ▶  ნავიგაცია     OK  არჩევა"
                android:textColor="#0CFFFFFF"
                android:textSize="9sp"
                android:letterSpacing="0.07"
                android:layout_marginTop="5dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>