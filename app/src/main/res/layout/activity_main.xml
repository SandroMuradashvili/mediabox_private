<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ── LOGO top-left ──────────────────────────────────── -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="140dp"
            android:layout_height="29dp"
            android:src="@drawable/ic_mediabox_logo"
            android:scaleType="fitStart"
            android:contentDescription="Mediabox"
            android:layout_marginStart="48dp"
            android:layout_marginTop="26dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Greeting sub-text -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#18FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.04"
            android:layout_marginStart="50dp"
            android:layout_marginTop="3dp"
            app:layout_constraintTop_toBottomOf="@id/ivLogo"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ── CLOCK + DATE group top-right ──────────────────── -->
        <LinearLayout
            android:id="@+id/clockGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginEnd="48dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#C8F1F5F9"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.04"
                android:fontFamily="sans-serif-light"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon, 1 Jan"
                android:textColor="#28FFFFFF"
                android:textSize="10sp"
                android:gravity="end"
                android:letterSpacing="0.06"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- ── DIVIDER ────────────────────────────────────────── -->
        <View
            android:id="@+id/dividerTop"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#07FFFFFF"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="48dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/clockGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ═══ CARDS ROW ════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cardsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/dividerTop"
            app:layout_constraintBottom_toTopOf="@+id/hintBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ── CARD: WATCH TV ─────────────────────────────── -->
            <FrameLayout
                android:id="@+id/cardWatchTv"
                android:layout_width="260dp"
                android:layout_height="289dp"
                android:layout_margin="12dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.1"
                        android:gravity="center">

                        <ImageView
                            android:tag="icon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu_watch"
                            android:alpha="0.22"
                            android:scaleType="fitCenter"
                            android:contentDescription="Watch TV"/>

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:paddingStart="26dp"
                        android:paddingEnd="26dp"
                        android:paddingBottom="26dp">

                        <View
                            android:tag="labelAccent"
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:background="#E8191A"
                            android:layout_marginBottom="10dp"
                            android:alpha="0"/>

                        <TextView
                            android:tag="label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Watch TV"
                            android:textColor="#F1F5F9"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            android:alpha="0.50"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live · Archive · HD"
                            android:textColor="#14FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>

            <!-- ── CARD: PROFILE ──────────────────────────────── -->
            <FrameLayout
                android:id="@+id/cardProfile"
                android:layout_width="260dp"
                android:layout_height="289dp"
                android:layout_margin="12dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.1"
                        android:gravity="center">

                        <ImageView
                            android:tag="icon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu_profile"
                            android:alpha="0.22"
                            android:scaleType="fitCenter"
                            android:contentDescription="Profile"/>

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:paddingStart="26dp"
                        android:paddingEnd="26dp"
                        android:paddingBottom="26dp">

                        <View
                            android:tag="labelAccent"
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:background="#E8191A"
                            android:layout_marginBottom="10dp"
                            android:alpha="0"/>

                        <TextView
                            android:tag="label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Profile"
                            android:textColor="#F1F5F9"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            android:alpha="0.50"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Account · Subscription"
                            android:textColor="#14FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>

            <!-- ── CARD: PLANS ────────────────────────────────── -->
            <FrameLayout
                android:id="@+id/cardSettings"
                android:layout_width="260dp"
                android:layout_height="289dp"
                android:layout_margin="12dp"
                android:background="@drawable/menu_card_glass"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.1"
                        android:gravity="center">

                        <ImageView
                            android:tag="icon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu_settings"
                            android:alpha="0.22"
                            android:scaleType="fitCenter"
                            android:contentDescription="Plans"/>

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:paddingStart="26dp"
                        android:paddingEnd="26dp"
                        android:paddingBottom="26dp">

                        <View
                            android:tag="labelAccent"
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:background="#E8191A"
                            android:layout_marginBottom="10dp"
                            android:alpha="0"/>

                        <TextView
                            android:tag="label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="პაკეტები"
                            android:textColor="#F1F5F9"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            android:alpha="0.50"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="პაკეტები · ბალანსი"
                            android:textColor="#14FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- ── BOTTOM HINT BAR ────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/hintBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvSelectionHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Watch live TV and archive content"
                android:textColor="#20FFFFFF"
                android:textSize="11sp"
                android:letterSpacing="0.02"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀  ▶  Navigate     OK  Select"
                android:textColor="#0EFFFFFF"
                android:textSize="9sp"
                android:letterSpacing="0.06"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>