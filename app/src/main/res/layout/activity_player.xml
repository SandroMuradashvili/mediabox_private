<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- 1. The Player: texture_view allows us to hide initialization mess with a placeholder -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        app:use_controller="false"
        app:surface_type="texture_view"
        app:resize_mode="fixed_width"
        app:shutter_background_color="@android:color/black"
        app:show_buffering="never"
        app:use_artwork="false" />

    <!-- 2. The Black Placeholder: Sits ON TOP of the player to hide resizing -->
    <View
        android:id="@+id/videoPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="visible" />

    <!-- 3. Control Overlay -->
    <include
        android:id="@+id/controlOverlay"
        layout="@layout/overlay_controls"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 4. EPG Overlay -->
    <include
        android:id="@+id/epgOverlay"
        layout="@layout/overlay_epg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 5. Loading Indicator (Hidden by default to avoid circles) -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

    <!-- Number Input Overlay (Top Right) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/numberInputCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="40dp"
        app:cardBackgroundColor="#E61E293B"
        app:cardCornerRadius="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvNumberInputDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textColor="#F1F5F9"
            android:textSize="40sp"
            android:textStyle="bold"
            android:text="12"/>
    </androidx.cardview.widget.CardView>

    <!-- Inactivity Countdown Overlay -->
    <FrameLayout
        android:id="@+id/inactivityOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true">

    <androidx.cardview.widget.CardView
            android:layout_width="450dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="16dp"
            app:cardElevation="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvInactivityTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Are you still watching?"
                    android:textColor="#F1F5F9"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvInactivityMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The app will close in 300 seconds"
                    android:textColor="#94A3B8"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp"
                    android:gravity="center"/>

                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:background="#6366F1"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:id="@+id/tvInactivityHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Press any button to stay"
                    android:textColor="#6366F1"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:letterSpacing="0.05"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

</FrameLayout>