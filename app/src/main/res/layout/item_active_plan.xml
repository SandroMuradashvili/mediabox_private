<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="160dp"
    android:orientation="vertical"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:padding="20dp"
    android:background="@drawable/purchased_plan_background">

    <!-- Plan name -->
    <TextView
        android:id="@+id/tvActivePlanName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plan Name"
        android:textColor="#F1F5F9"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"/>

    <!-- Price - Money Green -->
    <TextView
        android:id="@+id/tvActivePlanPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₾ 0.00"
        android:textColor="#10B981"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        android:layout_marginTop="4dp"/>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Expiry date -->
    <TextView
        android:id="@+id/tvActivePlanExpiry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expires —"
        android:textColor="#3D5A7A"
        android:textSize="11sp"/>

    <!-- Days left -->
    <TextView
        android:id="@+id/tvActivePlanDays"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="— days left"
        android:textColor="#10B981"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp"/>

</LinearLayout>