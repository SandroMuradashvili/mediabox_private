<?xml version="1.0" encoding="utf-8"?>
<!--
    overlay_track_selection.xml
    Slides in from the right — a slim frosted panel listing quality / audio tracks.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <!-- Panel anchored to right edge -->
    <androidx.cardview.widget.CardView
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        app:cardBackgroundColor="#F0101828"
        app:cardCornerRadius="0dp"
        app:cardElevation="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:background="#0CFFFFFF">

                <!-- Accent dot -->
                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/epg_accent_dot"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvTrackTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Video Quality"
                    android:textColor="#F1F5F9"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Close"
                    android:textColor="#2294A3B8"
                    android:textSize="10sp"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0DFFFFFF"/>

            <!-- Track list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTracks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:scrollbars="none"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>