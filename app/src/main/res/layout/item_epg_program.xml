<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/programContainer"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="1dp"
    android:layout_marginBottom="1dp"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:background="@drawable/epg_program_glass_item">

    <!-- Accent bar for currently playing -->
    <View
        android:id="@+id/programAccentBar"
        android:layout_width="3dp"
        android:layout_height="20dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/epg_program_accent_bar"
        android:visibility="invisible"/>

    <!-- Time — fixed width -->
    <TextView
        android:id="@+id/tvProgramTime"
        android:layout_width="94dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#C46366F1"
        android:singleLine="true"/>

    <!-- Title — takes remaining space -->
    <TextView
        android:id="@+id/tvProgramTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="16sp"
        android:textColor="#F1F5F9"
        android:singleLine="true"
        android:ellipsize="end"/>

    <!-- Hidden description — keep for adapter compat -->
    <TextView
        android:id="@+id/tvProgramDescription"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <!-- LIVE pill badge — only shown when program is live AND playing live (not archive) -->
    <!-- Animated Broadcast Icon (Replaces the text pill) -->
    <ImageView
        android:id="@+id/ivLiveBadge"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:translationX="5dp"
        android:src="@drawable/ic_broadcast_animated"
        android:visibility="gone"/>

    <!-- Playing Animation — shown for both live AND archive-watched program -->
    <ImageView
        android:id="@+id/ivPlayingAnim"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_playing_bars"
        android:visibility="gone"/>

    <!-- Keep original ID but hide it completely -->
    <TextView
        android:id="@+id/tvNowBadge"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <!-- Date — far right, e.g. "23 Feb" -->
    <TextView
        android:id="@+id/tvProgramDate"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#8094A3B8"
        android:gravity="end"
        android:singleLine="true"
        android:layout_marginStart="8dp"/>

</LinearLayout>