<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0D1117"
    android:focusable="false"
    android:clickable="false">

    <!-- ══ LEFT: Brand identity (42%) ══════════════════════════════ -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_weight="0.42"
        android:layout_height="match_parent"
        android:background="@drawable/login_left_bg"
        android:focusable="false"
        android:clickable="false">

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="#10FFFFFF"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="start"
            android:focusable="false"
            android:clickable="false">

            <ImageView
                android:id="@+id/ivLogoLeft"
                android:layout_width="180dp"
                android:layout_height="37dp"
                android:src="@drawable/ic_mediabox_logo"
                android:scaleType="fitStart"
                android:contentDescription="Mediabox"
                android:focusable="false"
                android:clickable="false"/>

            <View
                android:layout_width="100dp"
                android:layout_height="1dp"
                android:background="#1AE52121"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREMIUM STREAMING"
                android:textColor="#4094A3B8"
                android:textSize="9sp"
                android:letterSpacing="0.22"
                android:textStyle="bold"
                android:focusable="false"
                android:clickable="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Live TV  ·  Archive  ·  HD"
                android:textColor="#2094A3B8"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:focusable="false"
                android:clickable="false"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ══ RIGHT: QR Card (58%) ═════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_weight="0.58"
        android:layout_height="match_parent"
        android:focusable="false"
        android:clickable="false">

        <LinearLayout
            android:layout_width="450dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/login_card_glass"
            android:padding="40dp"
            android:focusable="false"
            android:clickable="false">

            <!-- Card Header: CENTERED Title + TOP-RIGHT Lang Toggle -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:focusable="false"
                android:clickable="false">

                <TextView
                    android:id="@+id/tvSignInTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Sign In"
                    android:textColor="#F1F5F9"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:focusable="false"
                    android:clickable="false"/>

                <!-- Language Toggle Button -->
                <FrameLayout
                    android:id="@+id/btnLoginLang"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/login_button_selector"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_profile_language"
                        app:tint="#F1F5F9"/>
                </FrameLayout>
            </RelativeLayout>

            <TextView
                android:id="@+id/tvSignInSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan the code to register this device"
                android:textColor="#6094A3B8"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:focusable="false"
                android:clickable="false"/>

            <!-- QR frame -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false"
                android:descendantFocusability="blocksDescendants">

                <FrameLayout
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:background="#FFFFFF"
                    android:padding="10dp"
                    android:focusable="false"
                    android:clickable="false">
                    <ImageView
                        android:id="@+id/ivQrCode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:focusable="false"
                        android:clickable="false"/>
                </FrameLayout>

                <!-- Corner brackets (EPG Red) -->
                <View android:layout_width="16dp" android:layout_height="2.5dp" android:background="#E52121" android:layout_gravity="top|start" android:layout_margin="-1.5dp"/>
                <View android:layout_width="2.5dp" android:layout_height="16dp" android:background="#E52121" android:layout_gravity="top|start" android:layout_margin="-1.5dp"/>
                <View android:layout_width="16dp" android:layout_height="2.5dp" android:background="#E52121" android:layout_gravity="top|end" android:layout_margin="-1.5dp"/>
                <View android:layout_width="2.5dp" android:layout_height="16dp" android:background="#E52121" android:layout_gravity="top|end" android:layout_margin="-1.5dp"/>
                <View android:layout_width="16dp" android:layout_height="2.5dp" android:background="#E52121" android:layout_gravity="bottom|start" android:layout_margin="-1.5dp"/>
                <View android:layout_width="2.5dp" android:layout_height="16dp" android:background="#E52121" android:layout_gravity="bottom|start" android:layout_margin="-1.5dp"/>
                <View android:layout_width="16dp" android:layout_height="2.5dp" android:background="#E52121" android:layout_gravity="bottom|end" android:layout_margin="-1.5dp"/>
                <View android:layout_width="2.5dp" android:layout_height="16dp" android:background="#E52121" android:layout_gravity="bottom|end" android:layout_margin="-1.5dp"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvPairingCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginTop="20dp"
                android:focusable="false"
                android:clickable="false"/>

            <TextView
                android:id="@+id/tvManualUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="tv-api.telecomm1.com/tv-register"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:alpha="0.6"
                android:layout_marginTop="6dp"
                android:focusable="false"
                android:clickable="false"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for scan..."
                android:textColor="#3394A3B8"
                android:textSize="11sp"
                android:layout_marginTop="12dp"
                android:focusable="false"
                android:clickable="false"/>

            <!-- Replace the existing btnRefresh FrameLayout with this updated version -->
            <FrameLayout
                android:id="@+id/btnRefresh"
                android:layout_width="180dp"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/login_button_selector"
                android:focusable="true"
                android:clickable="true"
                android:visibility="gone"
                android:clipToPadding="false"
                android:clipChildren="false">

                <TextView
                    android:id="@+id/tvRefreshLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="REFRESH"
                    android:textColor="#F1F5F9"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>