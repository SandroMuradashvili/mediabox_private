<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#040911">

    <ge.mediabox.mediabox.ui.ParticleFieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- LEFT: Branding -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="0.45"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEDIA"
                android:textColor="#FFFFFF"
                android:textSize="56sp"
                android:textStyle="bold"/>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/logo_accent_pill">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BOX"
                    android:textColor="#FFFFFF"
                    android:textSize="56sp"
                    android:textStyle="bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREMIUM STREAMING"
                android:textColor="#60FFFFFF"
                android:textSize="11sp"
                android:letterSpacing="0.25"
                android:layout_marginTop="20dp"/>

        </LinearLayout>

        <!-- RIGHT: QR Login -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="0.55"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:cardBackgroundColor="#12FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign In"
                        android:textColor="#F1F5F9"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan with your phone to log in"
                        android:textColor="#5594A3B8"
                        android:textSize="13sp"
                        android:layout_marginBottom="28dp"/>

                    <!-- QR Code -->
                    <FrameLayout
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:background="#FFFFFF"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/ivQrCode"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:contentDescription="Login QR Code"/>

                        <!-- Loading spinner shown while QR loads -->
                        <ProgressBar
                            android:id="@+id/pbQr"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="#6366F1"/>

                    </FrameLayout>

                    <!-- Pairing code -->
                    <TextView
                        android:id="@+id/tvPairingCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#818CF8"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.18"
                        android:layout_marginTop="20dp"/>

                    <!-- Status -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Initializing..."
                        android:textColor="#5594A3B8"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="12dp"/>

                    <!-- Refresh button (hidden until needed) -->
                    <Button
                        android:id="@+id/btnRefresh"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Refresh"
                        android:backgroundTint="#6366F1"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="16dp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>

</FrameLayout>