<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="450dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:gravity="center"
        android:background="@drawable/menu_card_glass">

        <!-- White Quality/HD Icon -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_quality"
            app:tint="#F1F5F9"
            android:layout_marginBottom="24dp"
            android:alpha="0.9"/>

        <TextView
            android:id="@+id/tvSubNotificationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subscription Expiring"
            android:textColor="#F1F5F9"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="-0.02"/>

        <TextView
            android:id="@+id/tvSubNotificationMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Premium plan expires in 2 days."
            android:textColor="#94A3B8"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:alpha="0.8"/>

        <!-- Primary Action Button: Logo Red matching Time Rewind style -->
        <Button
            android:id="@+id/btnSubNotificationOk"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:text="OK"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E52121"
            android:textSize="14sp"
            android:letterSpacing="0.08"
            android:focusable="true"
            app:cornerRadius="12dp"
            style="@style/Widget.AppCompat.Button.Colored"/>

    </LinearLayout>
</FrameLayout>