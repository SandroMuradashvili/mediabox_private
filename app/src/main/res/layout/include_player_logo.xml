<?xml version="1.0" encoding="utf-8"?>
<!--
    PLAYER LOGO — top-left overlay
    ─────────────────────────────────────────────────────────────
    Replace your existing "MB" placeholder TextView/ImageView
    in overlay_controls.xml with this ImageView block.

    Place this file as:  res/layout/include_player_logo.xml
    Then in overlay_controls.xml, replace the MB view with:
        <include layout="@layout/include_player_logo"/>

    OR simply copy the ImageView directly into overlay_controls.xml.
    ─────────────────────────────────────────────────────────────
-->
<ImageView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ivPlayerLogo"
    android:layout_width="90dp"
    android:layout_height="19dp"
    android:src="@drawable/ic_mediabox_logo"
    android:scaleType="fitStart"
    android:alpha="0.85"
    android:contentDescription="Mediabox"/>
