<?xml version="1.0" encoding="utf-8"?>
<!--
    PROFILE SCREEN — Recolored to match EPG/Dark Glass style
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg">

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#E52121"
        android:visibility="gone"/>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/contentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- ═══════════════════════════════════════════════════════════
             LEFT: Identity panel (32%)
             ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="0.32"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#BF0D1117"
            android:paddingStart="32dp"
            android:paddingEnd="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <!-- Logo top-left -->
            <ImageView
                android:id="@+id/ivUserLogo"
                android:layout_width="100dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_mediabox_logo"
                android:scaleType="fitStart"
                android:alpha="0.45"
                android:contentDescription="Mediabox"
                android:layout_marginBottom="28dp"/>

            <!-- Avatar + initial -->
            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/profile_avatar_bg"/>

                <TextView
                    android:id="@+id/tvAvatarInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="U"
                    android:textColor="#F1F5F9"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <!-- Display name -->
            <TextView
                android:id="@+id/tvDisplayName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#F1F5F9"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Username -->
            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\@username"
                android:textColor="#6094A3B8"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="20dp"/>

            <!-- Separator -->
            <View
                android:layout_width="32dp"
                android:layout_height="1dp"
                android:background="#1AE52121"
                android:layout_marginBottom="20dp"/>

            <!-- Email row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL"
                    android:textColor="#4094A3B8"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.14"/>
                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#F1F5F9"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:alpha="0.8"/>
            </LinearLayout>

            <!-- Phone row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHONE"
                    android:textColor="#4094A3B8"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.14"/>
                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#F1F5F9"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:alpha="0.8"/>
            </LinearLayout>

            <!-- Balance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BALANCE"
                    android:textColor="#4094A3B8"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.14"/>
                <TextView
                    android:id="@+id/tvBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₾ 0.00"
                    android:textColor="#10B981"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Device ID at bottom -->
            <TextView
                android:id="@+id/tvDeviceId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Device ID: —"
                android:textColor="#3394A3B8"
                android:textSize="9sp"
                android:letterSpacing="0.04"
                android:maxLines="2"/>

        </LinearLayout>

        <!-- Vertical separator -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#10FFFFFF"/>

        <!-- ═══════════════════════════════════════════════════════════
             RIGHT: Actions area (68%)
             ═══════════════════════════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="0.68"
            android:layout_height="match_parent">

            <!-- ── Action list + header ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                android:paddingTop="32dp"
                android:paddingBottom="24dp">

                <!-- Top bar: Back (left) + Lang (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="28dp">

                    <!-- Back button -->
                    <FrameLayout
                        android:id="@+id/btnBack"
                        android:layout_width="84dp"
                        android:layout_height="36dp"
                        android:background="@drawable/menu_card_glass"
                        android:focusable="false"
                        android:clickable="true">
                        <TextView
                            android:id="@+id/tvBackLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="← Back"
                            android:textColor="#F1F5F9"
                            android:textSize="12sp"
                            android:alpha="0.8"/>
                    </FrameLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <!-- Language toggle -->
                    <FrameLayout
                        android:id="@+id/btnUserLang"
                        android:layout_width="48dp"
                        android:layout_height="36dp"
                        android:background="@drawable/menu_card_glass"
                        android:focusable="false"
                        android:clickable="true">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_profile_language"
                            app:tint="#F1F5F9"/>
                        <TextView
                            android:id="@+id/tvUserLangLabel"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone"/>
                    </FrameLayout>

                </LinearLayout>

                <!-- ── Section label ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETTINGS"
                    android:textColor="#4094A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.16"
                    android:layout_marginBottom="10dp"/>

                <!-- ── ACTION ROW: Mobile Remote ── -->
                <FrameLayout
                    android:id="@+id/btnMobileRemote"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/profile_action_row"
                    android:focusable="false"
                    android:clickable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_profile_remote"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="16dp"
                            android:contentDescription="Remote"
                            app:tint="#F1F5F9"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvMobileRemoteLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mobile Remote"
                                android:textColor="#F1F5F9"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvMobileRemoteSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Use phone as TV remote"
                                android:textColor="#6094A3B8"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvMobileRemoteStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OFF"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/badge_archive_range"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:alpha="0.7"/>

                    </LinearLayout>
                </FrameLayout>

                <!-- ── Section label: Active Plans ── -->
                <TextView
                    android:id="@+id/tvActivePlansHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE PLANS"
                    android:textColor="#4094A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.16"
                    android:layout_marginBottom="10dp"/>

                <!-- ── Horizontal Plans List ── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvActivePlans"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clipToPadding="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:scrollbars="none"/>

                    <TextView
                        android:id="@+id/tvNoPlans"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="No active plans"
                        android:textColor="#6094A3B8"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:background="@drawable/profile_action_row"
                        android:visibility="gone"/>

                </FrameLayout>

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- ── DANGER SECTION LABEL ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION"
                    android:textColor="#4094A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.16"
                    android:layout_marginBottom="10dp"/>

                <!-- ── ACTION ROW: Sign Out ── -->
                <LinearLayout
                    android:id="@+id/rowSignOut"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/profile_danger_row"
                    android:focusable="false"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_profile_signout"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="Sign out"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvLogoutLabelNew"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign Out"
                            android:textColor="#F87171"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvLogoutSubNew"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="End current session"
                            android:textColor="#F87171"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            android:alpha="0.4"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════
                 PLANS PANEL — slides in from right
                 ═══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/plansPanelOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:visibility="gone">

                <!-- Dim scrim -->
                <View
                    android:layout_width="0dp"
                    android:layout_weight="0.32"
                    android:layout_height="match_parent"
                    android:background="#99000000"/>

                <!-- Panel -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="0.68"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="#BF0D1117"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="20dp">

                    <!-- Panel header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:id="@+id/tvDetailPlanName"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Plan Details"
                            android:textColor="#F1F5F9"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="← BACK"
                            android:textColor="#4094A3B8"
                            android:textSize="9sp"
                            android:letterSpacing="0.10"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDetailChannelCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#E52121"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvDetailHeaderNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Includes free channels and:"
                        android:textColor="#6094A3B8"
                        android:textSize="11sp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#10FFFFFF"
                        android:layout_marginBottom="12dp"/>

                    <!-- Channel grid -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPlanChannels"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:clipToPadding="false"
                        android:paddingBottom="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:scrollbars="vertical"/>

                </LinearLayout>
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- ══ PLAN SELECTION OVERLAY ══ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/planDetailsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F20D1117"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvDetailPlanNameOverlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
