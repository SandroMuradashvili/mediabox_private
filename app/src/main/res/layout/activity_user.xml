<?xml version="1.0" encoding="utf-8"?>
<!--
    PROFILE SCREEN — Redesigned
    Left 32%  : Identity panel (avatar, name, contact, balance, device ID)
    Right 68% : Action rows + Plans slide-in panel
    Navigation: Up/Down through action rows, Right on Plans row opens panel
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070D1A">

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#4A7FD4"
        android:visibility="gone"/>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/contentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- ═══════════════════════════════════════════════════════════
             LEFT: Identity panel (32%)
             ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="0.32"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#0A1220"
            android:paddingStart="32dp"
            android:paddingEnd="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <!-- Logo top-left -->
            <ImageView
                android:id="@+id/ivUserLogo"
                android:layout_width="100dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_mediabox_logo"
                android:scaleType="fitStart"
                android:alpha="0.35"
                android:contentDescription="Mediabox"
                android:layout_marginBottom="28dp"/>

            <!-- Avatar + initial -->
            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/profile_avatar_bg"/>

                <TextView
                    android:id="@+id/tvAvatarInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="U"
                    android:textColor="#F1F5F9"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <!-- Display name -->
            <TextView
                android:id="@+id/tvDisplayName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#F1F5F9"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Username -->
            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\@username"
                android:textColor="#243D5A"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="20dp"/>

            <!-- Separator -->
            <View
                android:layout_width="32dp"
                android:layout_height="1dp"
                android:background="#1C2E4A"
                android:layout_marginBottom="20dp"/>

            <!-- Email row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL"
                    android:textColor="#1C3050"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.14"/>
                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Phone row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHONE"
                    android:textColor="#1C3050"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.14"/>
                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Balance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BALANCE"
                    android:textColor="#1C3050"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.14"/>
                <TextView
                    android:id="@+id/tvBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₾ 0.00"
                    android:textColor="#10B981"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Device ID at bottom -->
            <TextView
                android:id="@+id/tvDeviceId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Device ID: —"
                android:textColor="#0F1E30"
                android:textSize="9sp"
                android:letterSpacing="0.04"
                android:maxLines="2"/>

            <!-- Hidden views kept for data binding compat -->
            <TextView android:id="@+id/tvRole"        android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/tvRoleLabel"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/tvEmailLabel"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/tvPhoneLabel"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/tvBalanceLabel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        </LinearLayout>

        <!-- Vertical separator -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#1C2E4A"/>

        <!-- ═══════════════════════════════════════════════════════════
             RIGHT: Actions area (68%)
             ═══════════════════════════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="0.68"
            android:layout_height="match_parent">

            <!-- ── Action list + header ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                android:paddingTop="32dp"
                android:paddingBottom="24dp">

                <!-- Top bar: Back (left) + Lang (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="28dp">

                    <!-- Back button -->
                    <FrameLayout
                        android:id="@+id/btnBack"
                        android:layout_width="84dp"
                        android:layout_height="36dp"
                        android:background="@drawable/menu_card_glass"
                        android:focusable="true"
                        android:clickable="true">
                        <TextView
                            android:id="@+id/tvBackLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="← Back"
                            android:textColor="#94A3B8"
                            android:textSize="12sp"/>
                    </FrameLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <!-- Language toggle -->
                    <LinearLayout
                        android:id="@+id/btnUserLang"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/menu_card_glass"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:focusable="true"
                        android:clickable="true">
                        <TextView
                            android:id="@+id/tvUserLangLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ENG"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Hidden btnLogout kept for code compat — not visible -->
                    <FrameLayout
                        android:id="@+id/btnLogout"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone"/>
                    <TextView android:id="@+id/tvLogoutLabel"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
                    <TextView android:id="@+id/tvLogoutSub"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

                </LinearLayout>

                <!-- ── Section label ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT"
                    android:textColor="#1C3050"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.16"
                    android:layout_marginBottom="10dp"/>

                <!-- ── ACTION ROW: Active Plans ── -->
                <LinearLayout
                    android:id="@+id/rowPlans"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/profile_action_row"
                    android:focusable="true"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_profile_plans"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="Plans"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvActivePlansHeader"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Plans"
                            android:textColor="#F1F5F9"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvNoPlans"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No active plans"
                            android:textColor="#3D5A7A"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Plan count badge -->
                    <TextView
                        android:id="@+id/tvPlanCountBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#4A7FD4"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/badge_archive_range"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:visibility="gone"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#1C3050"
                        android:textSize="22sp"
                        android:layout_marginStart="12dp"/>

                </LinearLayout>

                <!-- ── ACTION ROW: Mobile Remote ── -->
                <FrameLayout
                    android:id="@+id/btnMobileRemote"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/profile_action_row"
                    android:focusable="true"
                    android:clickable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_profile_remote"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="16dp"
                            android:contentDescription="Remote"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvMobileRemoteLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mobile Remote"
                                android:textColor="#F1F5F9"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvMobileRemoteSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Use phone as TV remote"
                                android:textColor="#3D5A7A"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvMobileRemoteStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OFF"
                            android:textColor="#3D5A7A"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/badge_archive_range"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>

                    </LinearLayout>
                </FrameLayout>

                <!-- ── ACTION ROW: Language ── -->
                <!-- Language is handled via btnUserLang in the top bar;
                     this hidden placeholder keeps focusZone=4 wiring intact -->

                <!-- ── Spacer ── -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- ── DANGER SECTION LABEL ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION"
                    android:textColor="#1C3050"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.16"
                    android:layout_marginBottom="10dp"/>

                <!-- ── ACTION ROW: Sign Out ── -->
                <LinearLayout
                    android:id="@+id/rowSignOut"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/profile_danger_row"
                    android:focusable="true"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_profile_signout"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="Sign out"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvLogoutLabelNew"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign Out"
                            android:textColor="#F87171"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvLogoutSubNew"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="End current session"
                            android:textColor="#3D2020"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Hint -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="▲▼ Navigate     OK Select     ← Back"
                    android:textColor="#0F1E30"
                    android:textSize="9sp"
                    android:letterSpacing="0.06"/>

                <!-- Hidden rvActivePlans — kept for code compat, not visible -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvActivePlans"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════
                 PLANS PANEL — slides in from right
                 ═══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/plansPanelOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:visibility="gone">

                <!-- Dim scrim behind panel (left side) -->
                <View
                    android:layout_width="0dp"
                    android:layout_weight="0.32"
                    android:layout_height="match_parent"
                    android:background="#88000000"/>

                <!-- Panel -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="0.68"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="#0C1526"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="20dp">

                    <!-- Panel header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:id="@+id/tvDetailPlanName"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Plan Details"
                            android:textColor="#F1F5F9"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="← BACK"
                            android:textColor="#1C3050"
                            android:textSize="9sp"
                            android:letterSpacing="0.10"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDetailChannelCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#4A7FD4"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvDetailHeaderNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Includes free channels and:"
                        android:textColor="#3D5A7A"
                        android:textSize="11sp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1C2E4A"
                        android:layout_marginBottom="12dp"/>

                    <!-- Channel grid -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPlanChannels"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:clipToPadding="false"
                        android:paddingBottom="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:scrollbars="none"/>

                </LinearLayout>
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- ══ PLAN SELECTION OVERLAY (full-screen, for individual plan details) ══ -->
    <!-- This is the existing planDetailsOverlay, kept for Kotlin code compat
         but now only the rvPlanChannels panel above is the primary UX -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/planDetailsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F20F172A"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvDetailPlanNameOverlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
