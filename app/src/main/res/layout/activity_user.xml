<?xml version="1.0" encoding="utf-8"?>
<!--
    PROFILE / USER SCREEN — FULL REDESIGN
    ─────────────────────────────────────────────────────────────
    Matches main menu aesthetic exactly:
      • Same main_bg + menu_card_glass drawables
      • Real ic_mediabox_logo top-left
      • No QR code anywhere
      • Left glass card: account info (name, plan, expiry, status)
      • Right column: connections stat + sign-out card
      • No ProgressBar
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ── LOGO top-left ──────────────────────────── -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="130dp"
            android:layout_height="27dp"
            android:src="@drawable/ic_mediabox_logo"
            android:scaleType="fitStart"
            android:contentDescription="Mediabox"
            android:layout_marginStart="48dp"
            android:layout_marginTop="26dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MY ACCOUNT"
            android:textColor="#16FFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.22"
            android:textStyle="bold"
            android:layout_marginStart="50dp"
            android:layout_marginTop="3dp"
            app:layout_constraintTop_toBottomOf="@id/ivLogo"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ── BACK top-right ─────────────────────────── -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#28FFFFFF"
            android:textSize="12sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginEnd="48dp"
            android:layout_marginTop="26dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── RULE ───────────────────────────────────── -->
        <View
            android:id="@+id/dividerTop"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#07FFFFFF"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="48dp"
            android:layout_marginTop="62dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ══ CONTENT ROW ═══════════════════════════════ -->
        <LinearLayout
            android:id="@+id/contentRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/dividerTop"
            app:layout_constraintBottom_toTopOf="@+id/hintBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ── LEFT: Account Info card (340×289dp) ─── -->
            <FrameLayout
                android:layout_width="340dp"
                android:layout_height="289dp"
                android:layout_margin="12dp"
                android:background="@drawable/menu_card_glass">

                <!-- Red top accent line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="top"
                    android:background="#E8191A"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp">

                    <!-- Avatar + name row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <!-- Avatar circle -->
                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="14dp">
                            <View
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/profile_avatar_bg"/>
                            <TextView
                                android:id="@+id/tvAvatarInitial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="U"
                                android:textColor="#F1F5F9"
                                android:textSize="20sp"
                                android:textStyle="bold"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDisplayName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Username"
                                android:textColor="#F1F5F9"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.01"/>

                            <TextView
                                android:id="@+id/tvAccountSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Premium member"
                                android:textColor="#16FFFFFF"
                                android:textSize="10sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#08FFFFFF"
                        android:layout_marginBottom="16dp"/>

                    <!-- Info rows -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="PLAN"
                            android:textColor="#18FFFFFF" android:textSize="9sp"
                            android:letterSpacing="0.14" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvPlan"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#CDF1F5F9" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="EXPIRES"
                            android:textColor="#18FFFFFF" android:textSize="9sp"
                            android:letterSpacing="0.14" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvExpiry"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#CDF1F5F9" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="STATUS"
                            android:textColor="#18FFFFFF" android:textSize="9sp"
                            android:letterSpacing="0.14" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Active"
                            android:textColor="#AAFFA07A"
                            android:textSize="13sp"/>
                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- ── RIGHT COLUMN: Stats + Logout ──────────── -->
            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="289dp"
                android:layout_margin="12dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Connections stat card -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/menu_card_glass"
                    android:focusable="true"
                    android:clickable="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⊕"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:alpha="0.16"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvConnectionsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#F1F5F9"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CONNECTIONS"
                            android:textColor="#12FFFFFF"
                            android:textSize="8sp"
                            android:letterSpacing="0.18"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </FrameLayout>

                <!-- Sign Out card -->
                <FrameLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/logout_card_bg"
                    android:focusable="true"
                    android:clickable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏻"
                            android:textColor="#E8191A"
                            android:textSize="20sp"
                            android:alpha="0.65"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign Out"
                            android:textColor="#F1F5F9"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Return to login"
                            android:textColor="#12FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── BOTTOM HINT ─────────────────────────────── -->
        <LinearLayout
            android:id="@+id/hintBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀  Navigate     OK  Select     ← Back"
                android:textColor="#0EFFFFFF"
                android:textSize="9sp"
                android:letterSpacing="0.06"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
