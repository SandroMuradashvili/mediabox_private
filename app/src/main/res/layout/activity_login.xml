<?xml version="1.0" encoding="utf-8"?>
<!--
    LOGIN SCREEN — SPLIT LAYOUT
    Left: full-bleed brand panel with animated gradient + logo
    Right: frosted glass card with login form
    TV-safe: all fields are focusable, tab/dpad navigable
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#040911">

    <!-- Full-bleed depth background -->
    <ge.mediabox.mediabox.ui.ParticleFieldView
        android:id="@+id/particleField"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- LEFT BRAND PANEL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Brand left column: 45% -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="0.45"
            android:layout_height="match_parent"
            android:background="@drawable/login_brand_panel">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Logo block -->
                <LinearLayout
                    android:id="@+id/logoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEDIA"
                        android:textColor="#FFFFFF"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.03"
                        android:lineSpacingMultiplier="0.9"/>

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/logo_accent_pill">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BOX"
                            android:textColor="#FFFFFF"
                            android:textSize="56sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.03"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:lineSpacingMultiplier="0.9"/>
                    </FrameLayout>

                </LinearLayout>

                <!-- Tagline -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PREMIUM STREAMING"
                    android:textColor="#60FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.25"
                    android:layout_marginTop="20dp"/>

                <!-- Decorative divider -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="#336366F1"
                    android:layout_marginTop="32dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live TV · Archive · HD"
                    android:textColor="#40FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

            <!-- Version bottom-left of brand panel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:text="v2.0"
                android:textColor="#20FFFFFF"
                android:textSize="11sp"
                android:layout_margin="20dp"/>

        </FrameLayout>

        <!-- RIGHT LOGIN PANEL: 55% -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="0.55"
            android:layout_height="match_parent"
            android:gravity="center">

            <!-- Frosted glass login card -->
            <LinearLayout
                android:id="@+id/loginCard"
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:background="@drawable/login_card_glass"
                android:padding="48dp">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textColor="#F1F5F9"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter your credentials to continue"
                    android:textColor="#5594A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="36dp"/>

                <!-- Error message (hidden by default) -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:background="@drawable/login_error_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    android:alpha="0"/>

                <!-- Username field -->
                <TextView
                    android:id="@+id/labelUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USERNAME"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.5"/>

                <FrameLayout
                    android:id="@+id/containerUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/login_field_normal">

                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:imeOptions="actionNext"
                        android:textColor="#F1F5F9"
                        android:textColorHint="#3394A3B8"
                        android:hint="your_username"
                        android:background="@null"
                        android:textSize="15sp"
                        android:singleLine="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"/>

                </FrameLayout>

                <!-- Password field -->
                <TextView
                    android:id="@+id/labelPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSWORD"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.5"/>

                <FrameLayout
                    android:id="@+id/containerPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="36dp"
                    android:background="@drawable/login_field_normal">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textColor="#F1F5F9"
                        android:textColorHint="#3394A3B8"
                        android:hint="••••••••"
                        android:background="@null"
                        android:textSize="15sp"
                        android:singleLine="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"/>

                </FrameLayout>

                <!-- Sign In button -->
                <TextView
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Sign In"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:gravity="center"
                    android:background="@drawable/login_button_bg"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"/>

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"
                    android:indeterminateTint="#6366F1"/>

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>