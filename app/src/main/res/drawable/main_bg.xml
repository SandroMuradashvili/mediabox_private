<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#070B14"/>
        </shape>
    </item>
    <!-- Subtle top-left warmth -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="55%p"
                android:centerX="0.1"
                android:centerY="0.0"
                android:startColor="#0A1020"
                android:endColor="#00000000"/>
        </shape>
    </item>
    <!-- Bottom-right cool depth -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="60%p"
                android:centerX="0.9"
                android:centerY="1.0"
                android:startColor="#08101A"
                android:endColor="#00000000"/>
        </shape>
    </item>
    <!-- Vignette edges -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="100%p"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#00000000"
                android:endColor="#66020409"/>
        </shape>
    </item>
</layer-list>
