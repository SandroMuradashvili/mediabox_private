<?xml version="1.0" encoding="utf-8"?>
<!--
    main_bg.xml
    Glassmorphism needs a rich background to work against.
    Deep navy-to-midnight gradient with subtle blue radial bloom.
    The semi-transparent cards will show this through them.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: very dark navy, not pure black -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#070D1A"/>
        </shape>
    </item>

    <!-- Center radial blue bloom — gives depth behind cards -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="70%p"
                android:centerX="0.5"
                android:centerY="0.45"
                android:startColor="#141F3D"
                android:endColor="#00000000"/>
        </shape>
    </item>

    <!-- Secondary radial — offset up-left for asymmetry -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="45%p"
                android:centerX="0.2"
                android:centerY="0.25"
                android:startColor="#0A1630"
                android:endColor="#00000000"/>
        </shape>
    </item>

    <!-- Bottom grounding: fade to pure black -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#18000000"
                android:endColor="#00000000"/>
        </shape>
    </item>

    <!-- Very faint red tint top-right — brand hint, barely visible -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="30%p"
                android:centerX="0.88"
                android:centerY="0.12"
                android:startColor="#06DC2626"
                android:endColor="#00000000"/>
        </shape>
    </item>

</layer-list>