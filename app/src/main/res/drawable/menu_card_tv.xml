<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark glass -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0E1629"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <!-- Color tint gradient bottom-up (indigo) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#1A6366F1"
                android:endColor="#00000000"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <!-- Glass edge border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#16FFFFFF"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
</layer-list>