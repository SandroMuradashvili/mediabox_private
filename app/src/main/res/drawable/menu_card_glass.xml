<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Flat fill: deep navy surface -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0C1526"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Single thin border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#1C2E4A"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

</layer-list>
