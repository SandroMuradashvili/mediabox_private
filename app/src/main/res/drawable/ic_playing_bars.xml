<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="24"
            android:viewportHeight="24">

            <!-- We start at Y=20 and go to Y=4 so it grows UPWARDS -->
            <!-- StrokeWidth 3 fits 5 bars nicely in a 24dp width -->
            <path
                android:name="b1"
                android:pathData="M4,20 L4,4"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="3"
                android:strokeLineCap="round"/>
            <path
                android:name="b2"
                android:pathData="M8,20 L8,4"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="3"
                android:strokeLineCap="round"/>
            <path
                android:name="b3"
                android:pathData="M12,20 L12,4"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="3"
                android:strokeLineCap="round"/>
            <path
                android:name="b4"
                android:pathData="M16,20 L16,4"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="3"
                android:strokeLineCap="round"/>
            <path
                android:name="b5"
                android:pathData="M20,20 L20,4"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="3"
                android:strokeLineCap="round"/>
        </vector>
    </aapt:attr>

    <!-- Animation for Bar 1 -->
    <target android:name="b1">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="400"
                android:valueFrom="0.2"
                android:valueTo="0.9"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
        </aapt:attr>
    </target>

    <!-- Animation for Bar 2 -->
    <target android:name="b2">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="600"
                android:valueFrom="0.3"
                android:valueTo="1.0"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
        </aapt:attr>
    </target>

    <!-- Animation for Bar 3 -->
    <target android:name="b3">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="500"
                android:valueFrom="0.2"
                android:valueTo="0.7"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
        </aapt:attr>
    </target>

    <!-- Animation for Bar 4 -->
    <target android:name="b4">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="750"
                android:valueFrom="0.4"
                android:valueTo="0.9"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
        </aapt:attr>
    </target>

    <!-- Animation for Bar 5 -->
    <target android:name="b5">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="450"
                android:valueFrom="0.1"
                android:valueTo="0.6"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
        </aapt:attr>
    </target>

</animated-vector>