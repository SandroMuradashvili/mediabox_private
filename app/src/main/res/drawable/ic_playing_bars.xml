<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <!-- 1. The Vector Graphic (increased to 20dp) -->
    <aapt:attr name="android:drawable">
        <vector
            android:width="20dp"
            android:height="20dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <!-- Bar 1 -->
            <group android:name="g1" android:pivotX="4" android:pivotY="20">
                <path
                    android:pathData="M4,10 L4,20"
                    android:strokeColor="#E52121"
                    android:strokeWidth="4"
                    android:strokeLineCap="round"/>
            </group>
            <!-- Bar 2 -->
            <group android:name="g2" android:pivotX="12" android:pivotY="20">
                <path
                    android:pathData="M12,10 L12,20"
                    android:strokeColor="#E52121"
                    android:strokeWidth="4"
                    android:strokeLineCap="round"/>
            </group>
            <!-- Bar 3 -->
            <group android:name="g3" android:pivotX="20" android:pivotY="20">
                <path
                    android:pathData="M20,10 L20,20"
                    android:strokeColor="#E52121"
                    android:strokeWidth="4"
                    android:strokeLineCap="round"/>
            </group>
        </vector>
    </aapt:attr>

    <!-- 2. The Animations for each bar -->
    <target android:name="g1">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="400"
                android:valueFrom="0.3"
                android:valueTo="1.0"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
        </aapt:attr>
    </target>

    <target android:name="g2">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="600"
                android:valueFrom="0.2"
                android:valueTo="1.0"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
        </aapt:attr>
    </target>

    <target android:name="g3">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="500"
                android:valueFrom="0.4"
                android:valueTo="1.0"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
        </aapt:attr>
    </target>

</animated-vector>