<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0C1220"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Faint red border to signal destructive action -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#22E8191A"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</layer-list>
