<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#08101E"/>
        </shape>
    </item>
    <!-- Indigo glow from center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="120%p"
                android:centerX="0.5"
                android:centerY="0.45"
                android:startColor="#1A1040"
                android:endColor="#00000000"/>
        </shape>
    </item>
    <!-- Right edge fade to match card panel -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00000000"
                android:endColor="#14050A18"/>
        </shape>
    </item>
</layer-list>