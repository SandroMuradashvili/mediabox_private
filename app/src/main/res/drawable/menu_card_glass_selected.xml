<?xml version="1.0" encoding="utf-8"?>
<!--
    menu_card_glass_selected.xml — focused state
    Single smooth red glow via one large negative-inset stroke.
    No stepped rings — just one soft halo + crisp border.
    Parent needs clipChildren="false" + clipToPadding="false".
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">



    <!-- Glass fill: slightly brighter navy than unselected -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#AA060F22"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Top sheen: stronger on selected -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#20FFFFFF"
                android:endColor="#00000000"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Crisp red border — defines the focused edge cleanly -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#BBE8191A"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

</layer-list>