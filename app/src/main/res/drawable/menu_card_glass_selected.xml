<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Lighter fill on focus -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#111E33"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Brighter border: red accent -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#E52121"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

</layer-list>
