<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Original dark glass background (staying dark inside) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#BF0D1117"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Keep the bold Logo Red border for selection -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#E52121"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>