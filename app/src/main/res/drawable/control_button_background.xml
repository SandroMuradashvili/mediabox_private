<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused: Red glow and border matching EPG selection -->
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <solid android:color="#4DE52121"/>
                    <size android:width="68dp" android:height="68dp"/>
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="oval">
                    <solid android:color="#E52121"/>
                    <stroke android:width="2dp" android:color="#FFFFFFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Normal: Glassy dark matching EPG/Login -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#BF0D1117"/>
            <stroke android:width="1dp" android:color="#1AFFFFFF"/>
        </shape>
    </item>
</selector>